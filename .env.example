# ============================================================
# TSS TICKETING — ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in your real values
# NEVER commit .env.local to git
# ============================================================

# ── Supabase (get from: supabase.com → your project → Settings → API) ─────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe (get from: dashboard.stripe.com → Developers → API keys) ───────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...   # From: Stripe → Webhooks → your endpoint → Signing secret

# ── App config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://tickets.theshuttlesocial.co.uk  # or your Vercel URL
ADMIN_SECRET=choose-a-long-random-password-here            # protects /admin

# ── Email (optional - for booking confirmations) ─────────────────────────────
# Using Resend (free 3k emails/mo): resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=bookings@theshuttlesocial.co.uk
